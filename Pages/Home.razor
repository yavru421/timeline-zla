@page "/"
@using TimelineZLA.Models
@using TimelineZLA.Services
@using Microsoft.AspNetCore.Components.Web
@inject TimelineStorageService Storage
@inject NavigationManager Navigation

<PageTitle>TimelineZLA - Lobby</PageTitle>

<div class="lobby-container">
    <div class="lobby-card glass-panel">
        <h1 class="neon-title">Timeline<span class="accent">ZLA</span></h1>
        <p class="subtitle">Secure P2P Sync Lobby</p>

        <div class="action-grid">
            
            <!-- Host Match -->
            <div class="action-zone create-zone">
                <div class="icon-pulse">
                    <span class="material-icons">add_circle</span>
                </div>
                <h3>Start New Job</h3>
                <p>Host a local timeline and generate a join code.</p>
                <div class="input-group">
                    <input type="text" @bind="newJobName" placeholder="Job Name (optional)" class="lobby-input" />
                    <button class="btn-primary start-btn" @onclick="CreateJob">
                        CREATE LOBBY
                    </button>
                </div>
            </div>

            <!-- Join Match -->
            <div class="action-zone join-zone">
                <div class="icon-pulse blue">
                    <span class="material-icons">satellite_alt</span>
                </div>
                <h3>Join Job</h3>
                <p>Connect to an active timeline via 6-digit code.</p>
                <div class="input-group">
                    <input type="text" @bind="joinCode" placeholder="Enter 6-Digit Code" class="lobby-input code-input" maxlength="6" />
                    <button class="btn-secondary join-btn" @onclick="JoinJob" disabled="@(joinCode.Length != 6)">
                        CONNECT P2P
                    </button>
                </div>
            </div>
            
        </div>
        
        @if (savedJobs.Any())
        {
            <div class="recent-jobs-section">
                <h4 class="section-title">Your Hosted Jobs</h4>
                <div class="job-list">
                    @foreach (var job in savedJobs.OrderByDescending(j => j.LastModified))
                    {
                        <div class="job-item">
                            <div class="job-info" @onclick="() => ResumeJob(job.JobId)">
                                @if (editingJobId == job.JobId)
                                {
                                    <input class="job-name-input"
                                           type="text"
                                           value="@editingJobName"
                                           @oninput="e => editingJobName = e.Value?.ToString() ?? string.Empty"
                                           @onblur="SaveJobName"
                                           @onkeydown="HandleJobNameKeydown"
                                           @onclick:stopPropagation="true"
                                           maxlength="60" />
                                }
                                else
                                {
                                    <div class="job-name-row">
                                        <span class="job-name">@job.JobName</span>
                                        <button class="btn-rename" title="Rename"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => StartRenameJob(job.JobId, job.JobName)">
                                            <span class="material-icons">edit</span>
                                        </button>
                                    </div>
                                }
                                <div class="job-stats">
                                    <span>@job.Entries.Count @(job.Entries.Count == 1 ? "entry" : "entries")</span>
                                    <span class="stat-sep">•</span>
                                    <span>@FormatRelativeTime(job.LastModified)</span>
                                </div>
                                <span class="job-code">@job.JobId</span>
                            </div>
                            <div class="job-meta">
                                @if (deleteConfirmId == job.JobId)
                                {
                                    <div class="delete-confirm" @onclick:stopPropagation="true">
                                        <span class="confirm-text">Delete?</span>
                                        <button class="btn-confirm-yes" @onclick="() => ConfirmDelete(job.JobId)">Yes</button>
                                        <button class="btn-confirm-no" @onclick="CancelDelete">No</button>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn-delete-job" title="Delete Job" @onclick:stopPropagation="true" @onclick="() => RequestDelete(job.JobId)">
                                        <span class="material-icons">delete_outline</span>
                                    </button>
                                    <span class="material-icons nav-arrow" @onclick="() => ResumeJob(job.JobId)">arrow_forward_ios</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<style>
    .lobby-container {
        min-height: calc(100vh - 60px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        background: radial-gradient(circle at center, rgba(35, 134, 54, 0.1) 0%, transparent 70%);
    }

    .glass-panel {
        background: rgba(13, 17, 23, 0.85);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        padding: 40px;
        width: 100%;
        max-width: 900px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        text-align: center;
    }

    .neon-title {
        font-size: 3rem;
        font-weight: 800;
        letter-spacing: -1px;
        margin-bottom: 5px;
        text-transform: uppercase;
    }

    .subtitle {
        color: var(--text-dark-muted);
        font-size: 1.1rem;
        margin-bottom: 40px;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .action-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 30px;
    }

    .action-zone {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        padding: 30px;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .action-zone:hover {
        transform: translateY(-5px);
        border-color: rgba(255, 255, 255, 0.15);
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    .create-zone:hover {
        border-color: var(--brand-accent);
        box-shadow: 0 10px 30px rgba(35, 134, 54, 0.2);
    }

    .join-zone:hover {
        border-color: #58a6ff;
        box-shadow: 0 10px 30px rgba(88, 166, 255, 0.2);
    }

    .icon-pulse {
        width: 60px;
        height: 60px;
        background: rgba(35, 134, 54, 0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        color: var(--brand-accent);
    }
    
    .icon-pulse.blue {
        background: rgba(88, 166, 255, 0.2);
        color: #58a6ff;
    }

    .input-group {
        display: flex;
        flex-direction: column;
        gap: 15px;
        margin-top: 25px;
    }

    .lobby-input {
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        padding: 15px;
        color: white;
        font-size: 1.1rem;
        text-align: center;
        transition: all 0.3s;
    }

    .lobby-input:focus {
        outline: none;
        border-color: rgba(255, 255, 255, 0.3);
        background: rgba(0, 0, 0, 0.5);
    }

    .code-input {
        font-family: monospace;
        letter-spacing: 5px;
        font-size: 1.5rem;
        font-weight: bold;
        text-transform: uppercase;
    }

    .start-btn {
        padding: 15px;
        font-size: 1.1rem;
        font-weight: bold;
        letter-spacing: 1px;
    }

    .join-btn {
        padding: 15px;
        font-size: 1.1rem;
        font-weight: bold;
        letter-spacing: 1px;
        background: rgba(88, 166, 255, 0.1);
        color: #58a6ff;
        border-color: rgba(88, 166, 255, 0.3);
    }
    
    .join-btn:not(:disabled):hover {
        background: #58a6ff;
        color: #0d1117;
    }

    .join-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    @@media (max-width: 768px) {
        .action-grid {
            grid-template-columns: 1fr;
        }
    }

    .recent-jobs-section {
        margin-top: 40px;
        text-align: left;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding-top: 20px;
    }

    .section-title {
        color: var(--text-dark-muted);
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 1px;
        margin-bottom: 15px;
    }

    .job-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .job-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 15px 20px;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .job-item:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.1);
        transform: translateX(5px);
    }

    .job-info {
        display: flex;
        flex-direction: column;
        gap: 4px;
        flex: 1;
        min-width: 0;
    }

    .job-name-row {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .btn-rename {
        background: transparent;
        border: none;
        color: rgba(255,255,255,0.2);
        cursor: pointer;
        padding: 2px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        transition: color 0.2s;
        opacity: 0;
    }
    .job-item:hover .btn-rename { opacity: 1; }
    .btn-rename:hover { color: var(--text-white); }
    .btn-rename .material-icons { font-size: 0.9rem; color: inherit; }

    .job-name-input {
        background: rgba(0,0,0,0.4);
        border: 1px solid rgba(88,166,255,0.5);
        border-radius: 6px;
        padding: 4px 10px;
        color: white;
        font-size: 1.1rem;
        font-weight: bold;
        outline: none;
        width: 100%;
    }

    .job-stats {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.78rem;
        color: var(--text-dark-muted);
    }
    .stat-sep { opacity: 0.4; }

    .job-name {
        color: var(--text-white);
        font-weight: bold;
        font-size: 1.1rem;
    }

    .job-code {
        color: var(--brand-accent);
        font-family: monospace;
        font-size: 0.9rem;
        letter-spacing: 1px;
    }

    .job-meta {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .job-meta .material-icons {
        color: var(--text-dark-muted);
        font-size: 1.2rem;
    }

    .nav-arrow {
        cursor: pointer;
        transition: color 0.2s;
    }
    .nav-arrow:hover { color: var(--text-white); }

    .btn-delete-job {
        background: transparent;
        border: none;
        color: var(--text-dark-muted);
        cursor: pointer;
        padding: 4px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        transition: all 0.2s;
    }
    .btn-delete-job:hover {
        color: #f85149;
        background: rgba(248, 81, 73, 0.1);
    }
    .btn-delete-job .material-icons { font-size: 1.2rem; color: inherit; }

    .delete-confirm {
        display: flex;
        align-items: center;
        gap: 8px;
        animation: fadeIn 0.15s ease;
    }
    .confirm-text {
        font-size: 0.8rem;
        color: #f85149;
        font-weight: bold;
        letter-spacing: 0.5px;
    }
    .btn-confirm-yes {
        background: #f85149;
        color: white;
        border: none;
        padding: 4px 10px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.8rem;
        font-weight: bold;
        transition: background 0.2s;
    }
    .btn-confirm-yes:hover { background: #da3633; }
    .btn-confirm-no {
        background: rgba(255,255,255,0.05);
        color: var(--text-dark-muted);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 4px 10px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.8rem;
        transition: all 0.2s;
    }
    .btn-confirm-no:hover { background: rgba(255,255,255,0.1); color: var(--text-white); }
</style>

@code {
    private string newJobName = string.Empty;
    private string joinCode = string.Empty;
    private List<Job> savedJobs = new();
    private string? deleteConfirmId = null;

    // Feature #2: Inline job rename
    private string? editingJobId = null;
    private string editingJobName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        savedJobs = await Storage.GetAllJobsAsync();
    }

    private async Task CreateJob()
    {
        var code = new Random().Next(100000, 999999).ToString();
        var job = new Job
        {
            JobId = code,
            JobName = string.IsNullOrWhiteSpace(newJobName) ? "Untitled Job" : newJobName
        };

        await Storage.SaveJobAsync(job);
        Navigation.NavigateTo($"/job/{code}");
    }

    private void JoinJob()
    {
        if (joinCode.Length == 6)
        {
            Navigation.NavigateTo($"/job/{joinCode}?role=guest");
        }
    }

    private void ResumeJob(string jobId)
    {
        Navigation.NavigateTo($"/job/{jobId}");
    }

    private void RequestDelete(string jobId) => deleteConfirmId = jobId;
    private void CancelDelete() => deleteConfirmId = null;

    private async Task ConfirmDelete(string jobId)
    {
        await Storage.DeleteJobAsync(jobId);
        savedJobs.RemoveAll(j => j.JobId == jobId);
        deleteConfirmId = null;
    }

    // Feature #2: Inline job name editing
    private void StartRenameJob(string jobId, string currentName)
    {
        editingJobId = jobId;
        editingJobName = currentName;
    }

    private async Task SaveJobName()
    {
        if (editingJobId == null) return;
        var job = savedJobs.FirstOrDefault(j => j.JobId == editingJobId);
        if (job != null && !string.IsNullOrWhiteSpace(editingJobName))
        {
            job.JobName = editingJobName.Trim();
            await Storage.SaveJobAsync(job);
        }
        editingJobId = null;
    }

    private async Task HandleJobNameKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SaveJobName();
        if (e.Key == "Escape") editingJobId = null;
    }

    // Feature #5: Relative time helper
    private static string FormatRelativeTime(DateTime utc)
    {
        var elapsed = DateTime.UtcNow - utc;
        if (elapsed.TotalSeconds < 60) return "just now";
        if (elapsed.TotalMinutes < 60) return $"{(int)elapsed.TotalMinutes}m ago";
        if (elapsed.TotalHours < 24) return $"{(int)elapsed.TotalHours}h ago";
        if (elapsed.TotalDays < 7) return $"{(int)elapsed.TotalDays}d ago";
        return utc.ToLocalTime().ToString("MMM dd");
    }
}
