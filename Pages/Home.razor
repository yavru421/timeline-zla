@page "/"
@using TimelineZLA.Models
@using TimelineZLA.Services
@inject TimelineStorageService Storage
@inject NavigationManager Navigation

<PageTitle>TimelineZLA - Lobby</PageTitle>

<div class="lobby-container">
    <div class="lobby-card glass-panel">
        <h1 class="neon-title">Timeline<span class="accent">ZLA</span></h1>
        <p class="subtitle">Secure P2P Sync Lobby</p>

        <div class="action-grid">
            
            <!-- Host Match -->
            <div class="action-zone create-zone">
                <div class="icon-pulse">
                    <span class="material-icons">add_circle</span>
                </div>
                <h3>Start New Job</h3>
                <p>Host a local timeline and generate a join code.</p>
                <div class="input-group">
                    <input type="text" @bind="newJobName" placeholder="Job Name (optional)" class="lobby-input" />
                    <button class="btn-primary start-btn" @onclick="CreateJob">
                        CREATE LOBBY
                    </button>
                </div>
            </div>

            <!-- Join Match -->
            <div class="action-zone join-zone">
                <div class="icon-pulse blue">
                    <span class="material-icons">satellite_alt</span>
                </div>
                <h3>Join Job</h3>
                <p>Connect to an active timeline via 6-digit code.</p>
                <div class="input-group">
                    <input type="text" @bind="joinCode" placeholder="Enter 6-Digit Code" class="lobby-input code-input" maxlength="6" />
                    <button class="btn-secondary join-btn" @onclick="JoinJob" disabled="@(joinCode.Length != 6)">
                        CONNECT P2P
                    </button>
                </div>
            </div>
            
        </div>
    </div>
</div>

<style>
    .lobby-container {
        min-height: calc(100vh - 60px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        background: radial-gradient(circle at center, rgba(35, 134, 54, 0.1) 0%, transparent 70%);
    }

    .glass-panel {
        background: rgba(13, 17, 23, 0.85);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        padding: 40px;
        width: 100%;
        max-width: 900px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        text-align: center;
    }

    .neon-title {
        font-size: 3rem;
        font-weight: 800;
        letter-spacing: -1px;
        margin-bottom: 5px;
        text-transform: uppercase;
    }

    .subtitle {
        color: var(--text-dark-muted);
        font-size: 1.1rem;
        margin-bottom: 40px;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .action-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 30px;
    }

    .action-zone {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        padding: 30px;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .action-zone:hover {
        transform: translateY(-5px);
        border-color: rgba(255, 255, 255, 0.15);
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    .create-zone:hover {
        border-color: var(--brand-accent);
        box-shadow: 0 10px 30px rgba(35, 134, 54, 0.2);
    }

    .join-zone:hover {
        border-color: #58a6ff;
        box-shadow: 0 10px 30px rgba(88, 166, 255, 0.2);
    }

    .icon-pulse {
        width: 60px;
        height: 60px;
        background: rgba(35, 134, 54, 0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        color: var(--brand-accent);
    }
    
    .icon-pulse.blue {
        background: rgba(88, 166, 255, 0.2);
        color: #58a6ff;
    }

    .input-group {
        display: flex;
        flex-direction: column;
        gap: 15px;
        margin-top: 25px;
    }

    .lobby-input {
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        padding: 15px;
        color: white;
        font-size: 1.1rem;
        text-align: center;
        transition: all 0.3s;
    }

    .lobby-input:focus {
        outline: none;
        border-color: rgba(255, 255, 255, 0.3);
        background: rgba(0, 0, 0, 0.5);
    }

    .code-input {
        font-family: monospace;
        letter-spacing: 5px;
        font-size: 1.5rem;
        font-weight: bold;
        text-transform: uppercase;
    }

    .start-btn {
        padding: 15px;
        font-size: 1.1rem;
        font-weight: bold;
        letter-spacing: 1px;
    }

    .join-btn {
        padding: 15px;
        font-size: 1.1rem;
        font-weight: bold;
        letter-spacing: 1px;
        background: rgba(88, 166, 255, 0.1);
        color: #58a6ff;
        border-color: rgba(88, 166, 255, 0.3);
    }
    
    .join-btn:not(:disabled):hover {
        background: #58a6ff;
        color: #0d1117;
    }

    .join-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    @@media (max-width: 768px) {
        .action-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private string newJobName = string.Empty;
    private string joinCode = string.Empty;

    private async Task CreateJob()
    {
        var code = new Random().Next(100000, 999999).ToString();
        var job = new Job
        {
            JobId = code,
            JobName = string.IsNullOrWhiteSpace(newJobName) ? "Untitled Job" : newJobName
        };

        await Storage.SaveJobAsync(job);
        Navigation.NavigateTo($"/job/{code}");
    }

    private void JoinJob()
    {
        if (joinCode.Length == 6)
        {
            Navigation.NavigateTo($"/job/{joinCode}?role=guest");
        }
    }
}
