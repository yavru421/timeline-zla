@page "/job/{JobCode}"
@using TimelineZLA.Models
@using TimelineZLA.Services
@using System.Text.Json
@inject TimelineStorageService Storage
@inject SyncService Sync
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>Timeline - @JobCode</PageTitle>

<div class="editor-container">
    <div class="editor-header">
        <div class="header-left">
            <button class="icon-btn" @onclick="GoHome">
                <span class="material-icons">arrow_back</span>
            </button>
            <span class="status-badge @(IsHost ? "host-badge" : "guest-badge")">
                @(IsHost ? "HOSTING" : "VIEWING")
            </span>
        </div>
        
        <div class="header-center">
            <div class="code-display">
                <span class="label">JOB CODE</span>
                <span class="code">@JobCode</span>
            </div>
        </div>

        <div class="header-right">
            <div class="sync-status @(isSyncing ? "sync-active" : "")">
                <span class="pulse-dot"></span>
                <span>@(isSyncing ? "Syncing..." : "Live")</span>
            </div>
        </div>
    </div>

    @if (!IsHost && !hasReceivedInitialData)
    {
        <div class="guest-waiting-overlay">
            <div class="spinner-modern"></div>
            <h3>Connecting to Host...</h3>
            <p>Waiting for P2P connection to @JobCode</p>
        </div>
    }

    <div class="timeline-canvas-wrapper">
        @if (currentJob.Entries.Count == 0)
        {
            <div class="empty-state">
                <h2>No entries yet</h2>
                <p>Start documenting the job by adding the first entry.</p>
                @if (IsHost)
                {
                    <button class="btn-primary" @onclick="AddNewEntry">Add First Entry</button>
                }
            </div>
        }
        else
        {
            <div class="vertical-timeline">
                @foreach (var entry in currentJob.Entries.OrderByDescending(e => e.Timestamp))
                {
                    <div class="timeline-item" @key="entry.Id">
                        <div class="timeline-marker">
                            <div class="marker-dot"></div>
                            <div class="marker-line"></div>
                        </div>
                        <div class="timeline-content">
                            <div class="timeline-meta">
                                <span class="time">@entry.Timestamp.ToLocalTime().ToString("MMM dd, yyyy - h:mm tt")</span>
                            </div>
                            <div class="card-editor">
                                <div id="zla-editor-@entry.Id" 
                                     class="apple-notes-editor @(IsHost ? "editable" : "readonly")" 
                                     contenteditable="@(IsHost ? "true" : "false")"
                                     placeholder="Type notes, or paste photos here..."
                                     @onblur="() => HandleBlur(entry.Id)">
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (IsHost)
                {
                    <div class="timeline-item add-new-item">
                        <div class="timeline-marker">
                            <div class="marker-dot pulse"></div>
                        </div>
                        <div class="timeline-content">
                            <button class="btn-add-entry" @onclick="AddNewEntry">
                                <span class="material-icons">add</span> Add Update
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .editor-container {
        display: flex;
        flex-direction: column;
        height: 100vh;
        background: var(--bg-main);
    }

    .editor-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 20px;
        background: rgba(13, 17, 23, 0.8);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border-dim);
        height: 60px;
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .header-left, .header-right {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .header-right {
        justify-content: flex-end;
    }

    .header-center {
        flex: 2;
        display: flex;
        justify-content: center;
    }

    .icon-btn {
        background: transparent;
        border: none;
        color: var(--text-white);
        cursor: pointer;
        padding: 8px;
        border-radius: 50%;
        transition: background 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .icon-btn:hover {
        background: rgba(255,255,255,0.1);
    }

    .status-badge {
        font-size: 0.75rem;
        font-weight: bold;
        padding: 4px 8px;
        border-radius: 4px;
        letter-spacing: 1px;
    }

    .host-badge { background: rgba(35, 134, 54, 0.2); color: #2ea043; }
    .guest-badge { background: rgba(88, 166, 255, 0.2); color: #58a6ff; }

    .code-display {
        text-align: center;
        background: rgba(0,0,0,0.3);
        padding: 4px 16px;
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .code-display .label {
        font-size: 0.7rem;
        color: var(--text-dark-muted);
        margin-right: 8px;
    }

    .code-display .code {
        font-family: monospace;
        font-size: 1.1rem;
        font-weight: bold;
        letter-spacing: 2px;
        color: #fff;
    }

    .sync-status {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
        color: var(--text-dark-muted);
    }

    .sync-status.sync-active {
        color: #2ea043;
    }

    .pulse-dot {
        width: 8px;
        height: 8px;
        background: currentColor;
        border-radius: 50%;
    }

    .sync-active .pulse-dot {
        animation: pulse 1.5s infinite;
    }

    .guest-waiting-overlay {
        position: absolute;
        top: 60px;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(13, 17, 23, 0.9);
        backdrop-filter: blur(10px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        z-index: 50;
    }

    .timeline-canvas-wrapper {
        flex: 1;
        overflow-y: auto;
        padding: 40px;
        display: flex;
        justify-content: center;
    }

    .vertical-timeline {
        width: 100%;
        max-width: 800px;
        display: flex;
        flex-direction: column;
    }

    .timeline-item {
        display: flex;
        position: relative;
        margin-bottom: 30px;
    }

    .timeline-marker {
        width: 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-right: 20px;
    }

    .marker-dot {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: var(--brand-accent);
        box-shadow: 0 0 10px rgba(46, 160, 67, 0.5);
        z-index: 2;
        margin-top: 5px;
    }

    .marker-line {
        width: 2px;
        flex: 1;
        background: var(--border-dim);
        position: absolute;
        top: 19px;
        bottom: -35px;
        left: 19px;
        z-index: 1;
    }

    .timeline-item:last-child .marker-line {
        display: none;
    }

    .timeline-content {
        flex: 1;
        background: var(--bg-card);
        border: 1px solid var(--border-dim);
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    }

    .timeline-meta {
        margin-bottom: 15px;
        color: var(--text-dark-muted);
        font-size: 0.85rem;
        font-weight: bold;
        letter-spacing: 1px;
    }

    .card-editor {
        min-height: 50px;
    }

    .apple-notes-editor {
        width: 100%;
        outline: none;
        color: var(--text-white);
        font-size: 1.05rem;
        line-height: 1.6;
    }

    .apple-notes-editor[placeholder]:empty:before {
        content: attr(placeholder);
        color: var(--text-dark-muted);
        pointer-events: none;
        display: block;
    }

    .apple-notes-editor img {
        max-width: 100%;
        border-radius: 8px;
        margin: 15px 0;
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    }
    
    .apple-notes-editor h1, .apple-notes-editor h2, .apple-notes-editor h3 {
        color: var(--text-white);
        margin-top: 1em;
        margin-bottom: 0.5em;
    }

    .empty-state {
        text-align: center;
        margin-top: 100px;
        color: var(--text-dark-muted);
    }

    .btn-primary {
        background: var(--brand-accent);
        color: white;
        border: none;
        padding: 12px 24px;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
        margin-top: 20px;
        transition: all 0.2s;
    }
    
    .btn-primary:hover {
        background: #3fb950;
        box-shadow: 0 0 15px rgba(46, 160, 67, 0.4);
    }

    .btn-add-entry {
        background: transparent;
        color: var(--text-dark-muted);
        border: 1px dashed var(--border-dim);
        padding: 15px;
        border-radius: 8px;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        cursor: pointer;
        font-weight: bold;
        transition: all 0.2s;
    }

    .btn-add-entry:hover {
        color: var(--text-white);
        border-color: var(--brand-accent);
        background: rgba(46, 160, 67, 0.1);
    }
    
    .marker-dot.pulse {
        background: transparent;
        border: 2px solid var(--text-dark-muted);
        box-shadow: none;
    }
</style>
