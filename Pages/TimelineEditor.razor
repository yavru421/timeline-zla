@page "/job/{JobCode}"
@using TimelineZLA.Models
@using TimelineZLA.Services
@using System.Text.Json
@inject TimelineStorageService Storage
@inject SyncService Sync
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>Timeline - @JobCode</PageTitle>

<div class="editor-container">
    <div class="editor-header">
        <div class="header-left">
            <button class="icon-btn" @onclick="GoHome">
                <span class="material-icons">arrow_back</span>
            </button>
            <span class="status-badge @(IsHost ? "host-badge" : "guest-badge")">
                @(IsHost ? "HOSTING" : "VIEWING")
            </span>
        </div>
        
        <div class="header-center">
            <div class="code-display">
                <span class="label">JOB CODE</span>
                <span class="code">@JobCode</span>
            </div>
        </div>

        <div class="header-right">
            <div class="sync-status @(isSyncing ? "sync-active" : "")">
                <span class="pulse-dot"></span>
                <span>@(isSyncing ? "Syncing..." : "Live")</span>
            </div>
        </div>
    </div>

    @if (!IsHost && !hasReceivedInitialData)
    {
        <div class="guest-waiting-overlay">
            <div class="spinner-modern"></div>
            <h3>Connecting to Host...</h3>
            <p>Waiting for P2P connection to @JobCode</p>
        </div>
    }

    <div class="editor-canvas-wrapper">
        <div id="zla-editor" 
             class="apple-notes-editor @(IsHost ? "editable" : "readonly")" 
             contenteditable="@(IsHost ? "true" : "false")"
             placeholder="Start typing notes, or paste photos here...">
        </div>
    </div>
</div>

<style>
    .editor-container {
        display: flex;
        flex-direction: column;
        height: 100vh;
        background: var(--bg-main);
    }

    .editor-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 20px;
        background: rgba(13, 17, 23, 0.8);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border-dim);
        height: 60px;
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .header-left, .header-right {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .header-right {
        justify-content: flex-end;
    }

    .header-center {
        flex: 2;
        display: flex;
        justify-content: center;
    }

    .icon-btn {
        background: transparent;
        border: none;
        color: var(--text-white);
        cursor: pointer;
        padding: 8px;
        border-radius: 50%;
        transition: background 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .icon-btn:hover {
        background: rgba(255,255,255,0.1);
    }

    .status-badge {
        font-size: 0.75rem;
        font-weight: bold;
        padding: 4px 8px;
        border-radius: 4px;
        letter-spacing: 1px;
    }

    .host-badge { background: rgba(35, 134, 54, 0.2); color: #2ea043; }
    .guest-badge { background: rgba(88, 166, 255, 0.2); color: #58a6ff; }

    .code-display {
        text-align: center;
        background: rgba(0,0,0,0.3);
        padding: 4px 16px;
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .code-display .label {
        font-size: 0.7rem;
        color: var(--text-dark-muted);
        margin-right: 8px;
    }

    .code-display .code {
        font-family: monospace;
        font-size: 1.1rem;
        font-weight: bold;
        letter-spacing: 2px;
        color: #fff;
    }

    .sync-status {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
        color: var(--text-dark-muted);
    }

    .sync-status.sync-active {
        color: #2ea043;
    }

    .pulse-dot {
        width: 8px;
        height: 8px;
        background: currentColor;
        border-radius: 50%;
    }

    .sync-active .pulse-dot {
        animation: pulse 1.5s infinite;
    }

    .guest-waiting-overlay {
        position: absolute;
        top: 60px;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(13, 17, 23, 0.9);
        backdrop-filter: blur(10px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        z-index: 50;
    }

    .editor-canvas-wrapper {
        flex: 1;
        overflow-y: auto;
        padding: 40px;
        display: flex;
        justify-content: center;
    }

    .apple-notes-editor {
        width: 100%;
        max-width: 800px;
        min-height: 100%;
        outline: none;
        color: var(--text-white);
        font-size: 1.15rem;
        line-height: 1.6;
    }

    .apple-notes-editor[placeholder]:empty:before {
        content: attr(placeholder);
        color: var(--text-dark-muted);
        pointer-events: none;
        display: block;
    }

    /* Inline media styling within the editor */
    .apple-notes-editor img {
        max-width: 100%;
        border-radius: 12px;
        margin: 20px 0;
        box-shadow: 0 4px 15px rgba(0,0,0,0.5);
    }
    
    .apple-notes-editor h1, .apple-notes-editor h2, .apple-notes-editor h3 {
        color: var(--brand-accent);
        margin-top: 1.5em;
    }
</style>
