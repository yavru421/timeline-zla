<Router AppAssembly="@typeof(App).Assembly" NotFoundPage="typeof(PourAndMeasure.Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(PourAndMeasure.Layout.MainLayout)"/>
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
</Router>
